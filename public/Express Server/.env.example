
# ─────────────────────────────────────────
#   Express Server — Environment Variables
#   Copy this file → .env and fill values
#   cp .env.example .env
# ─────────────────────────────────────────

# Required: server startup port
PORT=3000

# Required by startup banner/logging
NODE_ENV=development

# Optional: used by /api response payload
APP_NAME=Express Server
APP_VERSION=1.0.0


