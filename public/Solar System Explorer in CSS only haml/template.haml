!!!
%html{lang: "en"}
  %head
    %meta{charset: "UTF-8"}
    %meta{name: "viewport", content: "width=device-width, initial-scale=1.0"}
    %meta{name: "description", content: "Solar Explorer — an interactive educational guide to our solar system. Explore planets, moons, and fascinating space facts."}
    %link{rel: "stylesheet", href: "https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"}
    %link{rel: "preconnect", href: "https://fonts.googleapis.com"}
    %link{rel: "preconnect", href: "https://fonts.gstatic.com", crossorigin: true}
    %link{href: "https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap", rel: "stylesheet"}
    %link{rel: "stylesheet", href: "style.css"}
    %title Solar Explorer — Our Solar System

  %body
    / Back navigation
    %a.project-back-button{href: "/", "aria-label": "Back to home"}
      %i.fa-solid.fa-arrow-left{"aria-hidden": "true"}
      Back to Home

    / Animated star field background
    .star-field{"aria-hidden": "true"}
      .stars.stars--small
      .stars.stars--medium
      .stars.stars--large

    .app-shell
      / Header
      %header.site-header{role: "banner"}
        .site-header__brand
          %h1.logo
            %span.logo__icon{"aria-hidden": "true"} ☀
            Solar Explorer
            %span.logo__tagline Journey through our solar system

        .site-header__controls
          / Speed control
          .speed-controls{role: "group", "aria-label": "Animation speed controls"}
            %span.speed-controls__label Orbit Speed
            .speed-controls__buttons
              %button.speed-btn{"data-speed": "0.3", "aria-label": "Slow orbit speed", type: "button"} ½×
              %button.speed-btn.speed-btn--active{"data-speed": "1", "aria-label": "Normal orbit speed", type: "button"} 1×
              %button.speed-btn{"data-speed": "3", "aria-label": "Fast orbit speed", type: "button"} 3×

          / View mode toggle
          .view-controls{role: "group", "aria-label": "View mode"}
            %button.view-btn.view-btn--active#view-3d{"data-view": "3d", type: "button", "aria-label": "3D view", "aria-pressed": "true"}
              %i.fa-solid.fa-cube{"aria-hidden": "true"}
              3D
            %button.view-btn#view-2d{"data-view": "2d", type: "button", "aria-label": "2D view", "aria-pressed": "false"}
              %i.fa-solid.fa-map{"aria-hidden": "true"}
              2D

      / Exploration toolbar
      .exploration-toolbar{role: "toolbar", "aria-label": "Exploration tools"}
        .search-box
          %label.search-box__label{for: "planet-search"}
            %i.fa-solid.fa-magnifying-glass{"aria-hidden": "true"}
            %span.sr-only Search celestial bodies
          %input#planet-search.search-box__input{type: "search", placeholder: "Search planets, moons, dwarf planets…", "aria-autocomplete": "list", "aria-controls": "search-results"}
          %ul#search-results.search-results{role: "listbox", hidden: true}

        .toolbar-actions
          %button.toolbar-btn#zoom-in{type: "button", "aria-label": "Zoom in"}
            %i.fa-solid.fa-magnifying-glass-plus{"aria-hidden": "true"}
          %button.toolbar-btn#zoom-out{type: "button", "aria-label": "Zoom out"}
            %i.fa-solid.fa-magnifying-glass-minus{"aria-hidden": "true"}
          %button.toolbar-btn#reset-view{type: "button", "aria-label": "Reset view and focus on Earth"}
            %i.fa-solid.fa-rotate-left{"aria-hidden": "true"}
            Reset
          %button.toolbar-btn#open-compare{type: "button", "aria-label": "Compare planets"}
            %i.fa-solid.fa-scale-balanced{"aria-hidden": "true"}
            Compare
          %button.toolbar-btn#start-tour{type: "button", "aria-label": "Start guided tour"}
            %i.fa-solid.fa-route{"aria-hidden": "true"}
            Tour
          %button.toolbar-btn#open-quiz{type: "button", "aria-label": "Open space quiz"}
            %i.fa-solid.fa-graduation-cap{"aria-hidden": "true"}
            Quiz
          %button.toolbar-btn#open-timeline{type: "button", "aria-label": "Space exploration timeline"}
            %i.fa-solid.fa-clock-rotate-left{"aria-hidden": "true"}
            Timeline
          %button.toolbar-btn#open-concepts{type: "button", "aria-label": "Astronomy concepts"}
            %i.fa-solid.fa-lightbulb{"aria-hidden": "true"}
            Concepts

    / Sidebar header (visual only — does not break CSS sibling chain)
    .planet-nav__header{role: "navigation", "aria-label": "Planet navigation"}
      %p.planet-nav__heading Select a body
      %p.planet-nav__hint
        %i.fa-solid.fa-hand-pointer{"aria-hidden": "true"}
        Click a body to explore · Hover for quick facts
      %button.menu.menu--info.asteroid-belt{type: "button", "data-search": "asteroid belt ceres kuiper", "data-tooltip": "Millions of rocky fragments between Mars & Jupiter", "aria-label": "Learn about the asteroid belt"}
        %span.menu__preview.menu__preview--belt{"aria-hidden": "true"}
        %span.info
          %span.info__name
            %span.pip{"aria-hidden": "true"}
            Asteroid Belt
          %span.info__distance 2.2–3.2 AU · Region
        %span.menu__arrow{"aria-hidden": "true"}
          %i.fa-solid.fa-circle-info

    / Planet inputs + labels — alternating order required for CSS 3D engine
    %input.planet10#pluto{type: "radio", name: "planet", "aria-label": "Select Pluto"}
    %label.menu.pluto{for: "pluto", role: "button", tabindex: "0", "data-search": "pluto dwarf planet kuiper charon", "data-tooltip": "Dwarf planet — Kuiper Belt king"}
      %span.menu__preview{"aria-hidden": "true"}
      %span.info
        %span.info__name
          %span.pip{"aria-hidden": "true"}
          Pluto
        %span.info__distance 39.5 AU · Dwarf Planet
      %span.menu__arrow{"aria-hidden": "true"}
        %i.fa-solid.fa-chevron-right

    %input.planet9#neptune{type: "radio", name: "planet", "aria-label": "Select Neptune"}
    %label.menu.neptune{for: "neptune", role: "button", tabindex: "0", "data-search": "neptune planet ice giant triton", "data-tooltip": "Windiest planet — 2,100 km/h gusts"}
      %span.menu__preview{"aria-hidden": "true"}
      %span.info
        %span.info__name
          %span.pip{"aria-hidden": "true"}
          Neptune
        %span.info__distance 30.06 AU · Planet
      %span.menu__arrow{"aria-hidden": "true"}
        %i.fa-solid.fa-chevron-right

    %input.planet8#uranus{type: "radio", name: "planet", "aria-label": "Select Uranus"}
    %label.menu.uranus{for: "uranus", role: "button", tabindex: "0", "data-search": "uranus planet ice giant tilted", "data-tooltip": "Ice giant — rolls on its side"}
      %span.menu__preview{"aria-hidden": "true"}
      %span.info
        %span.info__name
          %span.pip{"aria-hidden": "true"}
          Uranus
        %span.info__distance 19.18 AU · Planet
      %span.menu__arrow{"aria-hidden": "true"}
        %i.fa-solid.fa-chevron-right

    %input.planet7#saturn{type: "radio", name: "planet", "aria-label": "Select Saturn"}
    %label.menu.saturn{for: "saturn", role: "button", tabindex: "0", "data-search": "saturn planet rings titan", "data-tooltip": "Iconic rings — 146 moons"}
      %span.menu__preview{"aria-hidden": "true"}
      %span.info
        %span.info__name
          %span.pip{"aria-hidden": "true"}
          Saturn
        %span.info__distance 9.539 AU · Planet
      %span.menu__arrow{"aria-hidden": "true"}
        %i.fa-solid.fa-chevron-right

    %input.planet6#jupiter{type: "radio", name: "planet", "aria-label": "Select Jupiter"}
    %label.menu.jupiter{for: "jupiter", role: "button", tabindex: "0", "data-search": "jupiter planet gas giant io europa", "data-tooltip": "Largest planet — 95 moons"}
      %span.menu__preview{"aria-hidden": "true"}
      %span.info
        %span.info__name
          %span.pip{"aria-hidden": "true"}
          Jupiter
        %span.info__distance 5.203 AU · Planet
      %span.menu__arrow{"aria-hidden": "true"}
        %i.fa-solid.fa-chevron-right

    %input.planet5#mars{type: "radio", name: "planet", "aria-label": "Select Mars"}
    %label.menu.mars{for: "mars", role: "button", tabindex: "0", "data-search": "mars planet red phobos deimos", "data-tooltip": "The Red Planet — 2 moons"}
      %span.menu__preview{"aria-hidden": "true"}
      %span.info
        %span.info__name
          %span.pip{"aria-hidden": "true"}
          Mars
        %span.info__distance 1.524 AU · Planet
      %span.menu__arrow{"aria-hidden": "true"}
        %i.fa-solid.fa-chevron-right

    %input.planet4#earth{type: "radio", name: "planet", checked: "checked", "aria-label": "Select Earth"}
    %label.menu.earth{for: "earth", role: "button", tabindex: "0", "data-search": "earth planet home moon", "data-tooltip": "Our home — only known life"}
      %span.menu__preview{"aria-hidden": "true"}
      %span.info
        %span.info__name
          %span.pip{"aria-hidden": "true"}
          Earth
        %span.info__distance 1 AU · Planet
      %span.menu__arrow{"aria-hidden": "true"}
        %i.fa-solid.fa-chevron-right

    %input.planet3#venus{type: "radio", name: "planet", "aria-label": "Select Venus"}
    %label.menu.venus{for: "venus", role: "button", tabindex: "0", "data-search": "venus planet morning star", "data-tooltip": "Hottest planet — 465°C surface"}
      %span.menu__preview{"aria-hidden": "true"}
      %span.info
        %span.info__name
          %span.pip{"aria-hidden": "true"}
          Venus
        %span.info__distance 0.723 AU · Planet
      %span.menu__arrow{"aria-hidden": "true"}
        %i.fa-solid.fa-chevron-right

    %input.planet2#mercury{type: "radio", name: "planet", "aria-label": "Select Mercury"}
    %label.menu.mercury{for: "mercury", role: "button", tabindex: "0", "data-search": "mercury planet rocky", "data-tooltip": "Smallest planet — 88-day year"}
      %span.menu__preview{"aria-hidden": "true"}
      %span.info
        %span.info__name
          %span.pip{"aria-hidden": "true"}
          Mercury
        %span.info__distance 0.39 AU · Planet
      %span.menu__arrow{"aria-hidden": "true"}
        %i.fa-solid.fa-chevron-right

    %input.planet1#sun{type: "radio", name: "planet", "aria-label": "Select Sun"}
    %label.menu.sun{for: "sun", role: "button", tabindex: "0", "data-search": "sun star", "data-tooltip": "Our star — 99.86% of solar system mass"}
      %span.menu__preview{"aria-hidden": "true"}
      %span.info
        %span.info__name
          %span.pip{"aria-hidden": "true"}
          Sun
        %span.info__distance 0 AU · Star
      %span.menu__arrow{"aria-hidden": "true"}
        %i.fa-solid.fa-chevron-right

    / Solar stage — must be a div immediately after label chain for CSS engine
    .solar-stage#solar-stage
      .solar-viewport#solar-viewport{role: "main", "aria-label": "Planet visualization"}
        .solar-viewport__hud{"aria-hidden": "true"}
          %span.viewport-hint
            %i.fa-solid.fa-arrows-up-down-left-right
            Drag to pan · Scroll to zoom
        .solar-scene#solar-scene
          .asteroid-belt-visual{"aria-hidden": "true"}
            .asteroid-belt-visual__ring
            .asteroid-belt-visual__label Asteroid Belt
          .solar{"aria-live": "polite"}

          / Sun
          %article.solar_systm{"aria-label": "Sun details"}
            .sun.planet{role: "img", "aria-label": "Sun visualization"}
              %section.sun.planet_description
                %h2.planet_description__type
                  %i.fa-solid.fa-star{"aria-hidden": "true"}
                  Star
                %h1.planet_description__name Sun
                %p.planet_description__summary
                  The Sun is the star at the center of our Solar System — a nearly perfect
                  sphere of hot plasma generating energy through nuclear fusion at its core.
                .planet_description__stats{"aria-label": "Quick facts"}
                  .stat-chip
                    %span.stat-chip__label Diameter
                    %span.stat-chip__value 1.39M km
                  .stat-chip
                    %span.stat-chip__label Surface Temp
                    %span.stat-chip__value 5,500°C
                  .stat-chip
                    %span.stat-chip__label Age
                    %span.stat-chip__value 4.6B years
                %label.planet_description__read-more{for: "readSun", role: "button", tabindex: "0"}
                  %i.fa-solid.fa-book-open{"aria-hidden": "true"}
                  Read Full Article
              .overlay{"aria-hidden": "true"}

          / Mercury
          %article.solar_systm{"aria-label": "Mercury details"}
            .mercury.planet{role: "img", "aria-label": "Mercury visualization"}
              %section.mercury.planet_description
                %h2.planet_description__type
                  %i.fa-solid.fa-circle-dot{"aria-hidden": "true"}
                  Planet
                %h1.planet_description__name Mercury
                %p.planet_description__summary
                  The closest planet to the Sun, racing through its orbit so fast that the
                  Romans named it after their swift-footed messenger god.
                .planet_description__stats{"aria-label": "Quick facts"}
                  .stat-chip
                    %span.stat-chip__label Year Length
                    %span.stat-chip__value 88 days
                  .stat-chip
                    %span.stat-chip__label Moons
                    %span.stat-chip__value 0
                  .stat-chip
                    %span.stat-chip__label Gravity
                    %span.stat-chip__value 3.7 m/s²
                %label.planet_description__read-more{for: "readMercury", role: "button", tabindex: "0"}
                  %i.fa-solid.fa-book-open{"aria-hidden": "true"}
                  Read Full Article
              .overlay{"aria-hidden": "true"}

          / Venus
          %article.solar_systm{"aria-label": "Venus details"}
            .planet.venus{role: "img", "aria-label": "Venus visualization"}
              %section.planet_description.venus
                %h2.planet_description__type
                  %i.fa-solid.fa-circle-dot{"aria-hidden": "true"}
                  Planet
                %h1.planet_description__name Venus
                %p.planet_description__summary
                  Named for the Roman goddess of love and beauty, Venus shines the brightest
                  of all planets — yet hides a hellish, crushing atmosphere beneath its clouds.
                .planet_description__stats{"aria-label": "Quick facts"}
                  .stat-chip
                    %span.stat-chip__label Day Length
                    %span.stat-chip__value 243 Earth days
                  .stat-chip
                    %span.stat-chip__label Moons
                    %span.stat-chip__value 0
                  .stat-chip
                    %span.stat-chip__label Temp
                    %span.stat-chip__value 465°C avg
                %label.planet_description__read-more{for: "readVenus", role: "button", tabindex: "0"}
                  %i.fa-solid.fa-book-open{"aria-hidden": "true"}
                  Read Full Article
              .overlay{"aria-hidden": "true"}

          / Earth
          %article.solar_systm{"aria-label": "Earth details"}
            .earth.planet{role: "img", "aria-label": "Earth visualization"}
              .moon.moon{role: "img", "aria-label": "Moon"}
                %span.moon__label Moon
                %span.moon__name Moon
              .m.trajectory{"aria-hidden": "true"}
              %section.earth.planet_description
                %h2.planet_description__type
                  %i.fa-solid.fa-earth-americas{"aria-hidden": "true"}
                  Planet
                %h1.planet_description__name Earth
                %p.planet_description__summary
                  Our home. The only planet known to harbour life, with liquid oceans, a
                  breathable atmosphere, and a magnetic field that shields us from solar wind.
                .planet_description__stats{"aria-label": "Quick facts"}
                  .stat-chip
                    %span.stat-chip__label Year Length
                    %span.stat-chip__value 365.25 days
                  .stat-chip
                    %span.stat-chip__label Moons
                    %span.stat-chip__value 1
                  .stat-chip
                    %span.stat-chip__label Surface Water
                    %span.stat-chip__value 71%
                %label.planet_description__read-more{for: "readEarth", role: "button", tabindex: "0"}
                  %i.fa-solid.fa-book-open{"aria-hidden": "true"}
                  Read Full Article
              .overlay{"aria-hidden": "true"}

          / Mars
          %article.solar_systm{"aria-label": "Mars details"}
            .mars.planet{role: "img", "aria-label": "Mars visualization"}
              .deimos.moon{role: "img", "aria-label": "Deimos moon"}
                %span.moon__label Moon
                %span.moon__name Deimos
              .d.trajectory{"aria-hidden": "true"}
              .moon.phoebos{role: "img", "aria-label": "Phobos moon"}
                %span.moon__label Moon
                %span.moon__name Phobos
              .p.trajectory{"aria-hidden": "true"}
              %section.mars.planet_description
                %h2.planet_description__type
                  %i.fa-solid.fa-circle-dot{"aria-hidden": "true"}
                  Planet
                %h1.planet_description__name Mars
                %p.planet_description__summary
                  The Red Planet, named for the Roman god of war. Home to Olympus Mons —
                  the tallest volcano in the solar system — and the target of humanity's
                  greatest exploration missions.
                .planet_description__stats{"aria-label": "Quick facts"}
                  .stat-chip
                    %span.stat-chip__label Year Length
                    %span.stat-chip__value 687 days
                  .stat-chip
                    %span.stat-chip__label Moons
                    %span.stat-chip__value 2
                  .stat-chip
                    %span.stat-chip__label Gravity
                    %span.stat-chip__value 37% of Earth
                %label.planet_description__read-more{for: "readMars", role: "button", tabindex: "0"}
                  %i.fa-solid.fa-book-open{"aria-hidden": "true"}
                  Read Full Article
              .overlay{"aria-hidden": "true"}

          / Jupiter
          %article.solar_systm{"aria-label": "Jupiter details"}
            .jupiter.planet{role: "img", "aria-label": "Jupiter visualization"}
              .lo.moon{role: "img", "aria-label": "Io moon"}
                %span.moon__label Moon
                %span.moon__name Io
              .europa.moon{role: "img", "aria-label": "Europa moon"}
                %span.moon__label Moon
                %span.moon__name Europa
              .ganymede.moon{role: "img", "aria-label": "Ganymede moon"}
                %span.moon__label Moon
                %span.moon__name Ganymede
              .lop.trajectory{"aria-hidden": "true"}
              .eu.trajectory{"aria-hidden": "true"}
              .ga.trajectory{"aria-hidden": "true"}
              %section.jupiter.planet_description
                %h2.planet_description__type
                  %i.fa-solid.fa-circle-dot{"aria-hidden": "true"}
                  Planet
                %h1.planet_description__name Jupiter
                %p.planet_description__summary
                  The king of planets — the largest body in our solar system after the Sun.
                  Its Great Red Spot, a storm larger than Earth, has raged for centuries.
                .planet_description__stats{"aria-label": "Quick facts"}
                  .stat-chip
                    %span.stat-chip__label Year Length
                    %span.stat-chip__value 11.8 Earth years
                  .stat-chip
                    %span.stat-chip__label Moons
                    %span.stat-chip__value 95
                  .stat-chip
                    %span.stat-chip__label Day Length
                    %span.stat-chip__value 9.9 hours
                %label.planet_description__read-more{for: "readJupiter", role: "button", tabindex: "0"}
                  %i.fa-solid.fa-book-open{"aria-hidden": "true"}
                  Read Full Article
              .overlay{"aria-hidden": "true"}

          / Saturn
          %article.solar_systm{"aria-label": "Saturn details"}
            .planet.saturn{role: "img", "aria-label": "Saturn visualization"}
              .moon.titan{role: "img", "aria-label": "Titan moon"}
                %span.moon__label Moon
                %span.moon__name Titan
              .dione.moon{role: "img", "aria-label": "Dione moon"}
                %span.moon__label Moon
                %span.moon__name Dione
              .enceladus.moon{role: "img", "aria-label": "Enceladus moon"}
                %span.moon__label Moon
                %span.moon__name Enceladus
              .ti.trajectory{"aria-hidden": "true"}
              .di.trajectory{"aria-hidden": "true"}
              .enc.trajectory{"aria-hidden": "true"}
              %section.planet_description.saturn
                %h2.planet_description__type
                  %i.fa-solid.fa-circle-dot{"aria-hidden": "true"}
                  Planet
                %h1.planet_description__name Saturn
                %p.planet_description__summary
                  The jewel of the solar system. Saturn's spectacular ring system —
                  made of ice and rock — extends 282,000 km from the planet's surface.
                .planet_description__stats{"aria-label": "Quick facts"}
                  .stat-chip
                    %span.stat-chip__label Year Length
                    %span.stat-chip__value 29.4 Earth years
                  .stat-chip
                    %span.stat-chip__label Moons
                    %span.stat-chip__value 146
                  .stat-chip
                    %span.stat-chip__label Ring Width
                    %span.stat-chip__value 282,000 km
                %label.planet_description__read-more{for: "readSaturn", role: "button", tabindex: "0"}
                  %i.fa-solid.fa-book-open{"aria-hidden": "true"}
                  Read Full Article
              .overlay{"aria-hidden": "true"}

          / Uranus
          %article.solar_systm{"aria-label": "Uranus details"}
            .planet.uranus{role: "img", "aria-label": "Uranus visualization"}
              .miranda.moon{role: "img", "aria-label": "Miranda moon"}
                %span.moon__label Moon
                %span.moon__name Miranda
              .ariel.moon{role: "img", "aria-label": "Ariel moon"}
                %span.moon__label Moon
                %span.moon__name Ariel
              .moon.umbriel{role: "img", "aria-label": "Umbriel moon"}
                %span.moon__label Moon
                %span.moon__name Umbriel
              .mir.trajectory{"aria-hidden": "true"}
              .ari.trajectory{"aria-hidden": "true"}
              .trajectory.umb{"aria-hidden": "true"}
              %section.planet_description.uranus
                %h2.planet_description__type
                  %i.fa-solid.fa-circle-dot{"aria-hidden": "true"}
                  Planet
                %h1.planet_description__name Uranus
                %p.planet_description__summary
                  An ice giant rolling on its side — Uranus has a dramatic 98° axial tilt,
                  meaning it orbits the Sun essentially on its side with poles pointing at it.
                .planet_description__stats{"aria-label": "Quick facts"}
                  .stat-chip
                    %span.stat-chip__label Year Length
                    %span.stat-chip__value 84 Earth years
                  .stat-chip
                    %span.stat-chip__label Moons
                    %span.stat-chip__value 28
                  .stat-chip
                    %span.stat-chip__label Axial Tilt
                    %span.stat-chip__value 98°
                %label.planet_description__read-more{for: "readUranus", role: "button", tabindex: "0"}
                  %i.fa-solid.fa-book-open{"aria-hidden": "true"}
                  Read Full Article
              .overlay{"aria-hidden": "true"}

          / Neptune
          %article.solar_systm{"aria-label": "Neptune details"}
            .neptune.planet{role: "img", "aria-label": "Neptune visualization"}
              .moon.triton{role: "img", "aria-label": "Triton moon"}
                %span.moon__label Moon
                %span.moon__name Triton
              .moon.proteus{role: "img", "aria-label": "Proteus moon"}
                %span.moon__label Moon
                %span.moon__name Proteus
              .moon.nereid{role: "img", "aria-label": "Nereid moon"}
                %span.moon__label Moon
                %span.moon__name Nereid
              .trajectory.tri{"aria-hidden": "true"}
              .pro.trajectory{"aria-hidden": "true"}
              .ner.trajectory{"aria-hidden": "true"}
              %section.neptune.planet_description
                %h2.planet_description__type
                  %i.fa-solid.fa-circle-dot{"aria-hidden": "true"}
                  Planet
                %h1.planet_description__name Neptune
                %p.planet_description__summary
                  The windiest planet in the solar system, with gusts reaching 2,100 km/h.
                  Neptune was the first planet discovered through mathematical prediction
                  rather than direct observation.
                .planet_description__stats{"aria-label": "Quick facts"}
                  .stat-chip
                    %span.stat-chip__label Year Length
                    %span.stat-chip__value 165 Earth years
                  .stat-chip
                    %span.stat-chip__label Moons
                    %span.stat-chip__value 16
                  .stat-chip
                    %span.stat-chip__label Wind Speed
                    %span.stat-chip__value 2,100 km/h
                %label.planet_description__read-more{for: "readNeptune", role: "button", tabindex: "0"}
                  %i.fa-solid.fa-book-open{"aria-hidden": "true"}
                  Read Full Article
              .overlay{"aria-hidden": "true"}

          / Pluto
          %article.solar_systm{"aria-label": "Pluto details"}
            .planet.pluto{role: "img", "aria-label": "Pluto visualization"}
              %section.planet_description.pluto
                %h2.planet_description__type
                  %i.fa-solid.fa-circle{"aria-hidden": "true"}
                  Dwarf Planet
                %h1.planet_description__name Pluto
                %p.planet_description__summary
                  Once the ninth planet, now the largest known dwarf planet. A member of
                  the Kuiper Belt — a shadowy zone of icy bodies beyond Neptune's orbit.
                .planet_description__stats{"aria-label": "Quick facts"}
                  .stat-chip
                    %span.stat-chip__label Year Length
                    %span.stat-chip__value 248 Earth years
                  .stat-chip
                    %span.stat-chip__label Moons
                    %span.stat-chip__value 5
                  .stat-chip
                    %span.stat-chip__label Reclassified
                    %span.stat-chip__value 2006
                %label.planet_description__read-more{for: "readPluto", role: "button", tabindex: "0"}
                  %i.fa-solid.fa-book-open{"aria-hidden": "true"}
                  Read Full Article
              .overlay{"aria-hidden": "true"}

