    / Astronomy concepts
    .feature-overlay#concepts-overlay{hidden: true, role: "dialog", "aria-modal": "true", "aria-labelledby": "concepts-title"}
      .feature-overlay__backdrop{"data-close": "concepts"}
      .feature-panel.feature-panel--wide
        %header.feature-panel__header
          %h2#concepts-title.feature-panel__title
            %i.fa-solid.fa-lightbulb{"aria-hidden": "true"}
            Astronomy Concepts
          %button.feature-panel__close{"data-close": "concepts", type: "button", "aria-label": "Close concepts"}
            %i.fa-solid.fa-xmark{"aria-hidden": "true"}
        .feature-panel__body
          .concept-grid
            .concept-card
              %h3
                %i.fa-solid.fa-sun{"aria-hidden": "true"}
                Seasons
              %p Earth's 23.5° axial tilt causes seasons. When a hemisphere tilts toward the Sun, it receives more direct sunlight and experiences summer.
              .concept-visual.concept-visual--seasons{"aria-hidden": "true"}
            .concept-card
              %h3
                %i.fa-solid.fa-circle-half-stroke{"aria-hidden": "true"}
                Eclipses
              %p A solar eclipse occurs when the Moon passes between Earth and the Sun. A lunar eclipse happens when Earth casts its shadow on the Moon.
              .concept-visual.concept-visual--eclipse{"aria-hidden": "true"}
            .concept-card
              %h3
                %i.fa-solid.fa-rotate{"aria-hidden": "true"}
                Orbital Motion
              %p Planets orbit the Sun in elliptical paths. Closer planets move faster — Mercury completes an orbit in 88 days, Neptune in 165 years.
              .concept-visual.concept-visual--orbit{"aria-hidden": "true"}
            .concept-card
              %h3
                %i.fa-solid.fa-meteor{"aria-hidden": "true"}
                Asteroid Belt
              %p Between Mars and Jupiter lies a ring of rocky debris — remnants from the early solar system. Ceres, the largest object, is classified as a dwarf planet.
              .concept-visual.concept-visual--belt{"aria-hidden": "true"}

    / Asteroid belt info
    .feature-overlay#belt-overlay{hidden: true, role: "dialog", "aria-modal": "true", "aria-labelledby": "belt-title"}
      .feature-overlay__backdrop{"data-close": "belt"}
      .feature-panel
        %header.feature-panel__header
          %h2#belt-title.feature-panel__title
            %i.fa-solid.fa-meteor{"aria-hidden": "true"}
            Asteroid Belt & Dwarf Planets
          %button.feature-panel__close{"data-close": "belt", type: "button", "aria-label": "Close asteroid belt info"}
            %i.fa-solid.fa-xmark{"aria-hidden": "true"}
        .feature-panel__body
          %p The asteroid belt contains millions of rocky fragments orbiting between Mars (1.5 AU) and Jupiter (5.2 AU), with a total mass less than Earth's Moon.
          .panel__fact-card
            %i.fa-solid.fa-lightbulb.panel__fact-icon{"aria-hidden": "true"}
            %p
              %strong Ceres
              is the largest object in the belt — 940 km across — and was reclassified as a dwarf planet in 2006 alongside Pluto.
          %h3 Notable Dwarf Planets
          %ul.dwarf-list
            %li
              %strong Pluto
              — Kuiper Belt, 2,377 km, 5 moons
            %li
              %strong Eris
              — Scattered disc, slightly smaller than Pluto
            %li
              %strong Haumea
              — Kuiper Belt, elongated rugby-ball shape
            %li
              %strong Makemake
              — Kuiper Belt, reddish icy surface
            %li
              %strong Ceres
              — Asteroid belt, only dwarf planet in inner solar system

    / Tooltip container
    #tooltip.tooltip{role: "tooltip", hidden: true}

    / ============================================================
    /  DETAIL PANELS
    / ============================================================

    / Sun panel
    %input.read{id: "readSun", type: "radio", name: "sunRead", "aria-label": "Read more about the Sun"}
    %label.closeBig{for: "closeSun", "aria-label": "Close Sun panel"}
    %input.read{id: "closeSun", type: "radio", name: "sunRead", "aria-label": "Close Sun panel"}
    %aside.panel{role: "complementary", "aria-label": "Sun detailed information"}
      %button.panel__close{onclick: "document.getElementById('closeSun').click()", "aria-label": "Close panel"}
        %i.fa-solid.fa-xmark{"aria-hidden": "true"}
      .panel__header.panel__header--sun
        %span.panel__type Star
        %h1.panel__title Sun
        %p.panel__subtitle The heart of our solar system
      .panel__body
        %p The Sun is the star at the center of the Solar System — a nearly perfect sphere of hot plasma, with internal convective motion that generates a magnetic field via a dynamo process.
        %figure.panel__figure
          %img{src: "https://upload.wikimedia.org/wikipedia/commons/b/b4/The_Sun_by_the_Atmospheric_Imaging_Assembly_of_NASA%27s_Solar_Dynamics_Observatory_-_20100819.jpg", alt: "The Sun photographed by NASA's Solar Dynamics Observatory showing its plasma surface"}
          %figcaption NASA Solar Dynamics Observatory — 2010
        .panel__fact-card
          %i.fa-solid.fa-lightbulb.panel__fact-icon{"aria-hidden": "true"}
          %p
            The Sun accounts for
            %strong 99.86%
            of the total mass in the solar system — roughly 330,000 times the mass of Earth.

    / Mercury panel
    %input.read{id: "readMercury", type: "radio", name: "mercuryRead", "aria-label": "Read more about Mercury"}
    %label.closeBig{for: "closeMercury", "aria-label": "Close Mercury panel"}
    %input.read{id: "closeMercury", type: "radio", name: "mercuryRead", "aria-label": "Close Mercury panel"}
    %aside.panel{role: "complementary", "aria-label": "Mercury detailed information"}
      %button.panel__close{onclick: "document.getElementById('closeMercury').click()", "aria-label": "Close panel"}
        %i.fa-solid.fa-xmark{"aria-hidden": "true"}
      .panel__header.panel__header--mercury
        %span.panel__type Planet
        %h1.panel__title Mercury
        %p.panel__subtitle The swift-footed messenger
      .panel__body
        %p Mercury is the closest planet to the Sun. It circles the Sun faster than all other planets, which is why Romans named it after their swift-footed messenger god.
        %p The Sumerians knew of Mercury since at least 5,000 years ago. Heraclitus, around 500 B.C., correctly thought that both Mercury and Venus orbited the Sun, not Earth.
        %figure.panel__figure
          %img{src: "https://i2.wp.com/www.astronomytrek.com/wp-content/uploads/2012/11/mercury-1.jpg?fit=678%2C381&ssl=1", alt: "Close-up photograph of Mercury's heavily cratered grey surface"}
          %figcaption Mercury's cratered surface
        .panel__fact-card
          %i.fa-solid.fa-lightbulb.panel__fact-icon{"aria-hidden": "true"}
          %p
            A year on Mercury is just
            %strong 88 Earth days,
            yet a solar day (noon to noon) lasts 176 Earth days — longer than its own year.
        %h2 Smallest planet in the Solar System
        %p Mercury is just 4,879 km across its equator, compared to 12,742 km for Earth. Despite its small size, it is the second densest planet — largely due to its heavy metallic core.
        %h2 Mercury has wrinkles
        %p As its iron core cooled and contracted, the surface buckled into ridges called Lobate Scarps — up to a mile high and hundreds of miles long.

    / Venus panel
    %input.read{id: "readVenus", type: "radio", name: "venusRead", "aria-label": "Read more about Venus"}
    %label.closeBig{for: "closeVenus", "aria-label": "Close Venus panel"}
    %input.read{id: "closeVenus", type: "radio", name: "venusRead", "aria-label": "Close Venus panel"}
    %aside.panel{role: "complementary", "aria-label": "Venus detailed information"}
      %button.panel__close{onclick: "document.getElementById('closeVenus').click()", "aria-label": "Close panel"}
        %i.fa-solid.fa-xmark{"aria-hidden": "true"}
      .panel__header.panel__header--venus
        %span.panel__type Planet
        %h1.panel__title Venus
        %p.panel__subtitle Brightest object in the night sky
      .panel__body
        %p Venus, the second planet from the Sun, is named for the Roman goddess of love and beauty. It may have been named for the most beautiful deity because it shone the brightest of the five planets known to ancient astronomers.
        %p In ancient times, Venus was thought to be two different stars — the evening star and the morning star. Further space-age observations reveal a hellish, crushing environment where spacecraft don't survive long on the surface.
        %figure.panel__figure
          %img{src: "https://3c1703fe8d.site.internapcdn.net/newman/gfx/news/hires/2014/2-whatistheave.jpg", alt: "False-colour radar map of Venus's surface showing highland regions"}
          %figcaption Venus surface radar map
        .panel__fact-card
          %i.fa-solid.fa-lightbulb.panel__fact-icon{"aria-hidden": "true"}
          %p
            A day on Venus lasts longer than its year. It takes
            %strong 243 Earth days
            to rotate once, but only 225 days to orbit the Sun.
        %h2 Spins backwards
        %p Venus rotates in the opposite direction to most planets — a retrograde rotation — possibly caused by an ancient collision with a large asteroid.
        %h2 Crushing atmosphere
        %p Atmospheric pressure on Venus is 92 times greater than Earth's, equivalent to the pressure experienced 900 metres underwater.

    / Earth panel
    %input.read{id: "readEarth", type: "radio", name: "earthRead", "aria-label": "Read more about Earth"}
    %label.closeBig{for: "closeEarth", "aria-label": "Close Earth panel"}
    %input.read{id: "closeEarth", type: "radio", name: "earthRead", "aria-label": "Close Earth panel"}
    %aside.panel{role: "complementary", "aria-label": "Earth detailed information"}
      %button.panel__close{onclick: "document.getElementById('closeEarth').click()", "aria-label": "Close panel"}
        %i.fa-solid.fa-xmark{"aria-hidden": "true"}
      .panel__header.panel__header--earth
        %span.panel__type Planet
        %h1.panel__title Earth
        %p.panel__subtitle Our pale blue dot
      .panel__body
        %p Earth is the third planet from the Sun and the only known world to harbour life. It is the only planet with free oxygen in its atmosphere, liquid oceans on its surface, and a rich biosphere.
        %p Earth is the fifth largest planet — smaller than the four gas giants, but larger than the other rocky planets.
        %figure.panel__figure
          %img{src: "https://images.pexels.com/photos/414171/pexels-photo-414171.jpeg?auto=compress&cs=tinysrgb&h=350", alt: "Earth's blue ocean and white clouds photographed from space"}
          %figcaption Earth from orbit
        .panel__fact-card
          %i.fa-solid.fa-lightbulb.panel__fact-icon{"aria-hidden": "true"}
          %p
            Earth's rotation is gradually slowing by about
            %strong 17 milliseconds per century.
            In 140 million years, a day will be 25 hours long.
        %h2 Powerful magnetic field
        %p Earth's nickel-iron core generates a magnetic field that deflects harmful solar wind and cosmic radiation, making complex life possible on the surface.
        %h2 The Moon
        %p Relative to the size of its parent planet, the Moon is the largest natural satellite in the solar system. Its gravitational pull stabilises Earth's axial tilt, helping maintain a stable climate over geological timescales.

    / Mars panel
    %input.read{id: "readMars", type: "radio", name: "marsRead", "aria-label": "Read more about Mars"}
    %label.closeBig{for: "closeMars", "aria-label": "Close Mars panel"}
    %input.read{id: "closeMars", type: "radio", name: "marsRead", "aria-label": "Close Mars panel"}
    %aside.panel{role: "complementary", "aria-label": "Mars detailed information"}
      %button.panel__close{onclick: "document.getElementById('closeMars').click()", "aria-label": "Close panel"}
        %i.fa-solid.fa-xmark{"aria-hidden": "true"}
      .panel__header.panel__header--mars
        %span.panel__type Planet
        %h1.panel__title Mars
        %p.panel__subtitle The Red Planet
      .panel__body
        %p Mars is the fourth planet from the Sun. The Romans named it after their god of war. The Egyptians called it "Her Desher" — the red one — while ancient Chinese astronomers dubbed it "the fire star."
        %figure.panel__figure
          %img{src: "https://1.bp.blogspot.com/-ou7Je3OVg6U/WYtxDqjNp_I/AAAAAAAACSQ/fsopS5VtFg4bmlv8hQNfiRYfJqTygCotQCLcBGAs/s2048/Martian%2Blandscape%2Bby%2BAmante%2BLombardi.jpg", alt: "Artistic rendering of the Martian landscape with rust-coloured rocky terrain"}
          %figcaption Martian landscape
        .panel__fact-card
          %i.fa-solid.fa-lightbulb.panel__fact-icon{"aria-hidden": "true"}
          %p
            Olympus Mons is the tallest mountain in the solar system —
            %strong 21 km high
            and 600 km in diameter, nearly three times the height of Everest.
        %h2 Similar landmass to Earth
        %p Despite only 15% of Earth's volume and 10% of its mass, Mars has roughly the same landmass — because two thirds of Earth's surface is covered in water. Martian gravity is 37% of Earth's.
        %h2 Planetary dust storms
        %p Mars experiences the largest dust storms in the solar system, capable of blanketing the entire planet for months at a time.

    / Jupiter panel
    %input.read{id: "readJupiter", type: "radio", name: "jupiterRead", "aria-label": "Read more about Jupiter"}
    %label.closeBig{for: "closeJupiter", "aria-label": "Close Jupiter panel"}
    %input.read{id: "closeJupiter", type: "radio", name: "jupiterRead", "aria-label": "Close Jupiter panel"}
    %aside.panel{role: "complementary", "aria-label": "Jupiter detailed information"}
      %button.panel__close{onclick: "document.getElementById('closeJupiter').click()", "aria-label": "Close panel"}
        %i.fa-solid.fa-xmark{"aria-hidden": "true"}
      .panel__header.panel__header--jupiter
        %span.panel__type Planet
        %h1.panel__title Jupiter
        %p.panel__subtitle King of the planets
      .panel__body
        %p Jupiter is the largest planet in the solar system. Named after the king of the Roman gods, it was also called Zeus by the ancient Greeks. In 1610, Galileo's discovery of four of its moons revolutionised our understanding of the universe.
        %p Galileo's observation that celestial bodies orbit something other than Earth was crucial support for the Copernican heliocentric model.
        %figure.panel__figure
          %img{src: "http://hanaleikauaivacation.com/wp-content/uploads/parser/jupiter-landscape-1.jpg", alt: "Jupiter's swirling cloud bands and Great Red Spot visible in this close-up"}
          %figcaption Jupiter's atmospheric bands
        .panel__fact-card
          %i.fa-solid.fa-lightbulb.panel__fact-icon{"aria-hidden": "true"}
          %p
            Jupiter has the
            %strong shortest day
            of all planets — rotating once every 9 hours and 55 minutes, despite being 11 times Earth's diameter.
        %h2 Fourth brightest object in the sky
        %p Only the Sun, Moon, and Venus are brighter. Jupiter is one of five planets visible to the naked eye from Earth.
        %h2 95 known moons
        %p Jupiter's Galilean moons — Io, Europa, Ganymede, and Callisto — are four of the most geologically fascinating worlds in the solar system, with Io being the most volcanically active body we know of.

    / Saturn panel
    %input.read{id: "readSaturn", type: "radio", name: "saturnRead", "aria-label": "Read more about Saturn"}
    %label.closeBig{for: "closeSaturn", "aria-label": "Close Saturn panel"}
    %input.read{id: "closeSaturn", type: "radio", name: "saturnRead", "aria-label": "Close Saturn panel"}
    %aside.panel{role: "complementary", "aria-label": "Saturn detailed information"}
      %button.panel__close{onclick: "document.getElementById('closeSaturn').click()", "aria-label": "Close panel"}
        %i.fa-solid.fa-xmark{"aria-hidden": "true"}
      .panel__header.panel__header--saturn
        %span.panel__type Planet
        %h1.panel__title Saturn
        %p.panel__subtitle Lord of the rings
      .panel__body
        %p Saturn is the sixth planet from the Sun and the second largest. Saturn was the Roman name for Cronus, lord of the Titans. Saturn is even the root of the English word "Saturday."
        %p The most distant planet visible to the naked eye, Saturn is most remarkable through a telescope — its ring system has no equal in the solar system.
        %figure.panel__figure
          %img{src: "http://ak0.picdn.net/shutterstock/videos/4049260/thumb/1.jpg", alt: "Saturn and its iconic ring system photographed against the black of space"}
          %figcaption Saturn and its ring system
        .panel__fact-card
          %i.fa-solid.fa-lightbulb.panel__fact-icon{"aria-hidden": "true"}
          %p
            Saturn is the
            %strong flattest planet
            — its polar diameter is only 90% of its equatorial diameter due to its low density and rapid rotation.
        %h2 Less dense than water
        %p Saturn has the lowest density of any planet — about 0.69 g/cm³, compared to water at 1 g/cm³. If you could find an ocean large enough, Saturn would float.
        %h2 146 moons
        %p Saturn has more moons than any other planet. Titan, its largest, is the only moon in the solar system with a thick atmosphere and liquid lakes — of methane — on its surface.

    / Uranus panel
    %input.read{id: "readUranus", type: "radio", name: "uranusRead", "aria-label": "Read more about Uranus"}
    %label.closeBig{for: "closeUranus", "aria-label": "Close Uranus panel"}
    %input.read{id: "closeUranus", type: "radio", name: "uranusRead", "aria-label": "Close Uranus panel"}
    %aside.panel{role: "complementary", "aria-label": "Uranus detailed information"}
      %button.panel__close{onclick: "document.getElementById('closeUranus').click()", "aria-label": "Close panel"}
        %i.fa-solid.fa-xmark{"aria-hidden": "true"}
      .panel__header.panel__header--uranus
        %span.panel__type Planet
        %h1.panel__title Uranus
        %p.panel__subtitle The tilted ice giant
      .panel__body
        %p Uranus is the seventh planet and the first to be discovered by scientists. Although visible to the naked eye, it was long mistaken for a dim star because of its slow orbit.
        %p British astronomer William Herschel discovered Uranus accidentally on March 13, 1781, while surveying the sky with his telescope. He first thought it was a comet.
        %figure.panel__figure
          %img{src: "http://www.cosmosup.com/wp-content/uploads/2016/02/Uranus-Facts-About-the-Planet-Uranus-700x325.jpg", alt: "Uranus shown as a pale blue sphere with its ring system visible edge-on"}
          %figcaption Uranus and its faint ring system
        .panel__fact-card
          %i.fa-solid.fa-lightbulb.panel__fact-icon{"aria-hidden": "true"}
          %p
            Uranus has a dramatic
            %strong 98° axial tilt
            — it effectively rolls around the Sun on its side. During some orbital positions, one pole faces the Sun directly for 42 years.
        %h2 An ice giant
        %p Unlike the gas giants Jupiter and Saturn, Uranus is mostly composed of icy materials — water, methane, and ammonia — above a rocky core. Methane in the atmosphere gives it its distinctive pale blue-green colour.
        %h2 Retrograde rotation
        %p Uranus rotates in the opposite direction to the Sun — one of only two planets to do so — completing one rotation every 17 hours 14 minutes.

    / Neptune panel
    %input.read{id: "readNeptune", type: "radio", name: "neptuneRead", "aria-label": "Read more about Neptune"}
    %label.closeBig{for: "closeNeptune", "aria-label": "Close Neptune panel"}
    %input.read{id: "closeNeptune", type: "radio", name: "neptuneRead", "aria-label": "Close Neptune panel"}
    %aside.panel{role: "complementary", "aria-label": "Neptune detailed information"}
      %button.panel__close{onclick: "document.getElementById('closeNeptune').click()", "aria-label": "Close panel"}
        %i.fa-solid.fa-xmark{"aria-hidden": "true"}
      .panel__header.panel__header--neptune
        %span.panel__type Planet
        %h1.panel__title Neptune
        %p.panel__subtitle The windswept ice giant
      .panel__body
        %p Neptune is the eighth planet from the Sun and the first to be predicted mathematically before it was ever observed. Irregularities in Uranus's orbit led astronomers to deduce Neptune's existence, and it was finally spotted on September 23, 1846.
        %p Only one mission has flown by Neptune — Voyager 2 in 1989 — leaving many mysteries about this distant, azure world.
        %figure.panel__figure
          %img{src: "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQy8Dd14tbXAzh1iz-EJl9tulRwH7Bb-SxX6sXpKFDbqb-NKwpE", alt: "Neptune as a deep blue sphere photographed by Voyager 2 in 1989"}
          %figcaption Neptune photographed by Voyager 2 — 1989
        .panel__fact-card
          %i.fa-solid.fa-lightbulb.panel__fact-icon{"aria-hidden": "true"}
          %p
            Neptune has the
            %strong fastest winds
            in the solar system — reaching up to 2,100 km/h, more than ten times the speed of Earth's most powerful hurricanes.
        %h2 Smallest ice giant
        %p Despite being smaller than Uranus, Neptune has greater mass. Below its hydrogen-helium atmosphere lies a mantle of water, ammonia, and methane ices above a rocky core.
        %h2 Blue from methane
        %p Methane in Neptune's upper atmosphere absorbs red light, reflecting blue — giving the planet its vivid, deep azure colour. Thin, high clouds drift above the blue haze.

    / Pluto panel
    %input.read{id: "readPluto", type: "radio", name: "plutoRead", "aria-label": "Read more about Pluto"}
    %label.closeBig{for: "closePluto", "aria-label": "Close Pluto panel"}
    %input.read{id: "closePluto", type: "radio", name: "plutoRead", "aria-label": "Close Pluto panel"}
    %aside.panel{role: "complementary", "aria-label": "Pluto detailed information"}
      %button.panel__close{onclick: "document.getElementById('closePluto').click()", "aria-label": "Close panel"}
        %i.fa-solid.fa-xmark{"aria-hidden": "true"}
      .panel__header.panel__header--pluto
        %span.panel__type Dwarf Planet
        %h1.panel__title Pluto
        %p.panel__subtitle King of the Kuiper Belt
      .panel__body
        %p Pluto, once the ninth planet, is now the largest known dwarf planet in the solar system. It is also one of the largest known members of the Kuiper Belt — a vast region of icy bodies beyond Neptune.
        %p In 2006, the IAU reclassified Pluto as a dwarf planet — a change that sparked debate in the scientific community and public alike. In 2017, a research group proposed expanding the planet count to roughly 100 based on a new "round objects in space" definition.
        %figure.panel__figure
          %img{src: "https://s3-us-west-2.amazonaws.com/s.cdpn.io/217233/asd.jpeg", alt: "Pluto photographed by New Horizons showing its heart-shaped nitrogen ice plain"}
          %figcaption Pluto's heart — Tombaugh Regio (New Horizons, 2015)
        .panel__fact-card
          %i.fa-solid.fa-lightbulb.panel__fact-icon{"aria-hidden": "true"}
          %p
            Pluto was discovered on
            %strong February 18, 1930
            by the Lowell Observatory. In the 76 years before its reclassification, it completed less than a third of one orbit around the Sun.
        %h2 Named by an 11-year-old
        %p Venetia Burney, an eleven-year-old schoolgirl from Oxford, England, proposed the name Pluto — after the Greek god of the underworld — upon learning of the discovery.
        %h2 Five moons
        %p Pluto has five known moons: Charon (1978), Nix and Hydra (2005), Kerberos (2011), and Styx (2012). Charon is so large relative to Pluto that the two are sometimes considered a double dwarf planet system.

    / JavaScript — interactivity layer
    :javascript
      (() => {
        'use strict';

        const $ = (sel, ctx = document) => ctx.querySelector(sel);
        const $$ = (sel, ctx = document) => [...ctx.querySelectorAll(sel)];

        const PLANET_DATA = {
          sun:     { name: 'Sun',     type: 'Star',         distance: '0 AU',      diameter: '1.39M km',  mass: '1.989×10³⁰ kg', gravity: '274 m/s²',  period: '—' },
          mercury: { name: 'Mercury', type: 'Planet',       distance: '0.39 AU',   diameter: '4,879 km',  mass: '3.30×10²³ kg',  gravity: '3.7 m/s²',  period: '88 days' },
          venus:   { name: 'Venus',   type: 'Planet',       distance: '0.723 AU',  diameter: '12,104 km', mass: '4.87×10²⁴ kg',  gravity: '8.87 m/s²', period: '225 days' },
          earth:   { name: 'Earth',   type: 'Planet',       distance: '1 AU',      diameter: '12,742 km', mass: '5.97×10²⁴ kg',  gravity: '9.81 m/s²', period: '365 days' },
          mars:    { name: 'Mars',    type: 'Planet',       distance: '1.524 AU',  diameter: '6,779 km',  mass: '6.42×10²³ kg',  gravity: '3.71 m/s²', period: '687 days' },
          jupiter: { name: 'Jupiter', type: 'Gas Giant',    distance: '5.203 AU',  diameter: '139,820 km',mass: '1.90×10²⁷ kg',  gravity: '24.79 m/s²',period: '11.9 years' },
          saturn:  { name: 'Saturn',  type: 'Gas Giant',    distance: '9.539 AU',  diameter: '116,460 km',mass: '5.68×10²⁶ kg',  gravity: '10.44 m/s²',period: '29.5 years' },
          uranus:  { name: 'Uranus',  type: 'Ice Giant',    distance: '19.18 AU',  diameter: '50,724 km', mass: '8.68×10²⁵ kg',  gravity: '8.69 m/s²', period: '84 years' },
          neptune: { name: 'Neptune', type: 'Ice Giant',    distance: '30.06 AU',  diameter: '49,244 km', mass: '1.02×10²⁶ kg',  gravity: '11.15 m/s²',period: '165 years' },
          pluto:   { name: 'Pluto',   type: 'Dwarf Planet', distance: '39.5 AU',   diameter: '2,377 km',  mass: '1.31×10²² kg',  gravity: '0.62 m/s²', period: '248 years' }
        };

        const FACTS = [
          'Jupiter\'s Great Red Spot is a storm larger than Earth that has raged for over 400 years.',
          'A day on Venus is longer than its year — 243 Earth days to rotate once.',
          'Neptune\'s winds can reach 2,100 km/h — the fastest in the solar system.',
          'Saturn would float in water — its density is less than 1 g/cm³.',
          'The Sun contains 99.86% of all mass in our solar system.',
          'Olympus Mons on Mars is nearly three times taller than Mount Everest.',
          'Uranus rotates on its side with a 98° axial tilt.',
          'Pluto was discovered in 1930 and reclassified as a dwarf planet in 2006.'
        ];

        const QUIZ = [
          { q: 'Which planet has the most moons?', options: ['Saturn', 'Jupiter', 'Neptune', 'Mars'], answer: 0 },
          { q: 'What is the hottest planet in our solar system?', options: ['Mercury', 'Venus', 'Mars', 'Jupiter'], answer: 1 },
          { q: 'Which planet was discovered through mathematical prediction?', options: ['Uranus', 'Neptune', 'Pluto', 'Mercury'], answer: 1 },
          { q: 'How long does light take to reach Earth from the Sun?', options: ['8 seconds', '8 minutes', '8 hours', '8 days'], answer: 1 },
          { q: 'Which is the largest dwarf planet?', options: ['Ceres', 'Eris', 'Pluto', 'Haumea'], answer: 2 }
        ];

        const TOUR = [
          { title: 'Welcome to Solar Explorer', body: 'This guided tour walks you through every major feature. Use the sidebar to pick any celestial body.', target: '.planet-nav__heading' },
          { title: 'Explore the 3D Viewport', body: 'Drag to pan and scroll to zoom. Switch between 2D and 3D modes using the view toggle in the header.', target: '#solar-viewport' },
          { title: 'Orbit Speed Controls', body: 'Adjust animation speed with ½×, 1×, or 3× buttons to watch planets rotate faster or slower.', target: '.speed-controls' },
          { title: 'Search & Compare', body: 'Use the search bar to find bodies instantly, then open Compare to see size, mass, gravity, and orbital data side by side.', target: '.exploration-toolbar' },
          { title: 'Learn More', body: 'Click "Read Full Article" on any planet for detailed science, images, and historical discoveries. Enjoy exploring!', target: '.facts-ticker' }
        ];

        let zoom = 1, panX = 0, panY = 0, quizIdx = 0, quizScore = 0, tourIdx = 0, factIdx = 0;

        const scene = $('#solar-scene');
        const viewport = $('#solar-viewport');

        const applyTransform = () => {
          if (!scene) return;
          scene.style.transform = `translate(${panX}px, ${panY}px) scale(${zoom})`;
        };

        const setSpeed = (speed) => {
          document.documentElement.style.setProperty('--orbit-speed-multiplier', speed);
          $$('.speed-btn').forEach((btn) => {
            btn.classList.toggle('speed-btn--active', parseFloat(btn.dataset.speed) === speed);
          });
        };

        $$('.speed-btn').forEach((btn) => {
          btn.addEventListener('click', () => setSpeed(parseFloat(btn.dataset.speed)));
        });

        $$('.view-btn').forEach((btn) => {
          btn.addEventListener('click', () => {
            $$('.view-btn').forEach((b) => {
              b.classList.toggle('view-btn--active', b === btn);
              b.setAttribute('aria-pressed', b === btn ? 'true' : 'false');
            });
            document.body.classList.toggle('view-2d', btn.dataset.view === '2d');
            document.body.classList.toggle('view-3d', btn.dataset.view === '3d');
          });
        });

        const resetView = () => {
          zoom = 1; panX = 0; panY = 0;
          applyTransform();
          const earth = $('#earth');
          if (earth) earth.checked = true;
        };

        $('#zoom-in')?.addEventListener('click', () => { zoom = Math.min(zoom + 0.15, 2.5); applyTransform(); });
        $('#zoom-out')?.addEventListener('click', () => { zoom = Math.max(zoom - 0.15, 0.5); applyTransform(); });
        $('#reset-view')?.addEventListener('click', resetView);

        let dragging = false, dragStart = { x: 0, y: 0 };
        viewport?.addEventListener('mousedown', (e) => {
          if (e.button !== 0) return;
          dragging = true;
          dragStart = { x: e.clientX - panX, y: e.clientY - panY };
          viewport.classList.add('is-dragging');
        });
        window.addEventListener('mousemove', (e) => {
          if (!dragging) return;
          panX = e.clientX - dragStart.x;
          panY = e.clientY - dragStart.y;
          applyTransform();
        });
        window.addEventListener('mouseup', () => {
          dragging = false;
          viewport?.classList.remove('is-dragging');
        });
        viewport?.addEventListener('wheel', (e) => {
          e.preventDefault();
          zoom = Math.min(Math.max(zoom + (e.deltaY < 0 ? 0.08 : -0.08), 0.5), 2.5);
          applyTransform();
        }, { passive: false });

        const openOverlay = (id) => {
          const el = $(`#${id}-overlay`);
          if (el) { el.hidden = false; document.body.classList.add('overlay-open'); }
        };
        const closeOverlay = (id) => {
          const el = $(`#${id}-overlay`);
          if (el) { el.hidden = true; document.body.classList.remove('overlay-open'); }
        };

        $('#open-compare')?.addEventListener('click', () => { populateCompare(); openOverlay('compare'); });
        $('#open-quiz')?.addEventListener('click', () => { quizIdx = 0; quizScore = 0; renderQuiz(); openOverlay('quiz'); });
        $('#start-tour')?.addEventListener('click', () => { tourIdx = 0; renderTour(); $('#tour-overlay').hidden = false; document.body.classList.add('overlay-open'); });
        $('#open-timeline')?.addEventListener('click', () => openOverlay('timeline'));
        $('#open-concepts')?.addEventListener('click', () => openOverlay('concepts'));
        $('.asteroid-belt')?.addEventListener('click', () => openOverlay('belt'));

        $$('[data-close]').forEach((el) => {
          el.addEventListener('click', () => closeOverlay(el.dataset.close));
        });

        const populateCompare = () => {
          const keys = Object.keys(PLANET_DATA);
          ['#compare-a', '#compare-b'].forEach((sel, i) => {
            const select = $(sel);
            if (!select) return;
            select.innerHTML = keys.map((k) => `<option value="${k}">${PLANET_DATA[k].name}</option>`).join('');
            select.value = i === 0 ? 'earth' : 'mars';
            select.addEventListener('change', updateCompare);
          });
          updateCompare();
        };

        const updateCompare = () => {
          const a = PLANET_DATA[$('#compare-a')?.value] || PLANET_DATA.earth;
          const b = PLANET_DATA[$('#compare-b')?.value] || PLANET_DATA.mars;
          $('#compare-col-a').textContent = a.name;
          $('#compare-col-b').textContent = b.name;
          const rows = [
            ['Type', 'type'], ['Distance from Sun', 'distance'], ['Diameter', 'diameter'],
            ['Mass', 'mass'], ['Surface Gravity', 'gravity'], ['Orbital Period', 'period']
          ];
          $('#compare-body').innerHTML = rows.map(([label, key]) =>
            `<tr><td>${label}</td><td>${a[key]}</td><td>${b[key]}</td></tr>`
          ).join('');
        };

        const renderQuiz = () => {
          const item = QUIZ[quizIdx];
          $('#quiz-progress').textContent = `Question ${quizIdx + 1} of ${QUIZ.length}`;
          $('#quiz-question').textContent = item.q;
          $('#quiz-feedback').textContent = '';
          $('#quiz-next').hidden = true;
          $('#quiz-options').innerHTML = item.options.map((opt, i) =>
            `<button class="quiz-option" type="button" data-idx="${i}">${opt}</button>`
          ).join('');
          $$('.quiz-option', $('#quiz-options')).forEach((btn) => {
            btn.addEventListener('click', () => {
              const correct = parseInt(btn.dataset.idx, 10) === item.answer;
              if (correct) quizScore++;
              $('#quiz-feedback').textContent = correct ? '✓ Correct!' : `✗ The answer is ${item.options[item.answer]}.`;
              $$('.quiz-option').forEach((b) => b.disabled = true);
              $('#quiz-next').hidden = false;
              $('#quiz-next').textContent = quizIdx < QUIZ.length - 1 ? 'Next Question' : `Finish — Score: ${quizScore}/${QUIZ.length}`;
            });
          });
        };

        $('#quiz-next')?.addEventListener('click', () => {
          if (quizIdx < QUIZ.length - 1) { quizIdx++; renderQuiz(); }
          else { closeOverlay('quiz'); }
        });

        const renderTour = () => {
          const step = TOUR[tourIdx];
          $('#tour-step').textContent = `Step ${tourIdx + 1} of ${TOUR.length}: ${step.title}`;
          $('#tour-body').textContent = step.body;
          $$('.tour-highlight').forEach((el) => el.classList.remove('tour-highlight'));
          const target = $(step.target);
          if (target) { target.classList.add('tour-highlight'); target.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }
        };

        $('#tour-next')?.addEventListener('click', () => {
          if (tourIdx < TOUR.length - 1) { tourIdx++; renderTour(); }
          else { $('#tour-overlay').hidden = true; document.body.classList.remove('overlay-open'); $$('.tour-highlight').forEach((el) => el.classList.remove('tour-highlight')); }
        });
        $('#tour-prev')?.addEventListener('click', () => { if (tourIdx > 0) { tourIdx--; renderTour(); } });
        $('#tour-skip')?.addEventListener('click', () => { $('#tour-overlay').hidden = true; document.body.classList.remove('overlay-open'); });

        const searchInput = $('#planet-search');
        const searchResults = $('#search-results');
        const searchable = $$('.menu[data-search]');

        searchInput?.addEventListener('input', () => {
          const q = searchInput.value.trim().toLowerCase();
          if (!q) { searchResults.hidden = true; return; }
          const matches = searchable.filter((el) => el.dataset.search.includes(q));
          searchResults.innerHTML = matches.map((el) => {
            const name = $('.info__name', el)?.textContent?.trim() || 'Result';
            return `<li role="option" tabindex="0" data-target="${el.htmlFor || ''}">${name}</li>`;
          }).join('');
          searchResults.hidden = matches.length === 0;
          $$('li', searchResults).forEach((li) => {
            li.addEventListener('click', () => {
              const target = $(`#${li.dataset.target}`);
              if (target) target.checked = true;
              else if (li.textContent.includes('Asteroid')) openOverlay('belt');
              searchInput.value = '';
              searchResults.hidden = true;
            });
          });
        });

        const tooltip = $('#tooltip');
        $$('.menu[data-tooltip]').forEach((el) => {
          el.addEventListener('mouseenter', (e) => {
            if (!tooltip) return;
            tooltip.textContent = el.dataset.tooltip;
            tooltip.hidden = false;
            tooltip.style.left = `${e.clientX + 12}px`;
            tooltip.style.top = `${e.clientY + 12}px`;
          });
          el.addEventListener('mouseleave', () => { if (tooltip) tooltip.hidden = true; });
        });

        const rotateFact = () => {
          const el = $('#fact-text');
          if (el) { el.textContent = FACTS[factIdx % FACTS.length]; factIdx++; }
        };
        rotateFact();
        setInterval(rotateFact, 8000);

        $$('.menu, .planet_description__read-more').forEach((el) => {
          el.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); el.click(); }
          });
        });

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') {
            $$('.feature-overlay:not([hidden])').forEach((o) => o.hidden = true);
            $('#tour-overlay').hidden = true;
            document.body.classList.remove('overlay-open');
          }
        });
      })();
