<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign Up</title>
  <link rel="stylesheet" href="login.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>

<body>

  <div class="page-wrapper">

    <!-- Lottie Animation -->
    <div class="image">
      <iframe src="https://lottie.host/embed/e9326b10-fe9a-446e-bc8d-56640e47e816/TeItgXRxNd.json"></iframe>
    </div>

    <!-- Signup Card -->
    <div class="card">
      <div class="card-header">
        <h1>Create Account</h1>
        <p>Join us today — it's free!</p>
      </div>

      <div class="form-body">

        <!-- Username -->
        <div class="field-group">
          <label for="username">Username</label>
          <input type="text" id="username" name="username" placeholder="Choose a username" autocomplete="username"
            required>
          <span class="error" id="err-username"></span>
        </div>

        <!-- Email -->
        <div class="field-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" placeholder="Enter your email" autocomplete="email" required>
          <span class="error" id="err-email"></span>
        </div>

        <!-- Password -->
        <div class="field-group">
          <label for="password">Password</label>
          <div class="password-container">
            <input type="password" id="password" name="password" placeholder="Create a strong password"
              autocomplete="new-password" required>
            <span class="toggle-password" onclick="togglePassword('password', this)">
              <i class="fa-regular fa-eye"></i>
            </span>
          </div>
          <span class="error" id="err-password"></span>
        </div>

        <!-- Confirm Password -->
        <div class="field-group">
          <label for="cpassword">Confirm Password</label>
          <div class="password-container">
            <input type="password" id="cpassword" name="cpassword" placeholder="Re-enter your password"
              autocomplete="new-password" required>
            <span class="toggle-password" onclick="togglePassword('cpassword', this)">
              <i class="fa-regular fa-eye"></i>
            </span>
          </div>
          <span class="error" id="err-cpassword"></span>
        </div>

        <!-- Register Button -->
        <button type="button" class="btn-primary" onclick="getDetails()">
          Create Account
        </button>

        <!-- Divider -->
        <div class="divider">or</div>

        <!-- Google Button -->
        <a href="/auth/google">
          <button type="button" class="google-btn">
            <i class="fa-brands fa-google"></i>
            Continue with Google
          </button>
        </a>

        <!-- Login Link -->
        <p class="register">
          Already a member? <a href="/">Login here!</a>
        </p>

      </div><!-- /.form-body -->
    </div><!-- /.card -->

  </div><!-- /.page-wrapper -->

  <!-- Toast Notification -->
  <div class="toast" id="toast"></div>

  <script>
    function showToast(msg, type = 'error') {
      const t = document.getElementById('toast');
      t.textContent = msg;
      t.className = `toast ${type} show`;
      setTimeout(() => t.classList.remove('show'), 3500);
    }

    function setError(id, msg) {
      document.getElementById(id).textContent = msg;
    }

    function clearErrors() {
      ['err-username', 'err-email', 'err-password', 'err-cpassword']
        .forEach(id => setError(id, ''));
    }

    async function getDetails() {
      clearErrors();

      const username = document.getElementById('username').value.trim();
      const email = document.getElementById('email').value.trim();
      const password = document.getElementById('password').value;
      const cpassword = document.getElementById('cpassword').value;

      let valid = true;

      if (!username) { setError('err-username', 'Username is required'); valid = false; }
      if (!email) { setError('err-email', 'Email is required'); valid = false; }
      if (!password) { setError('err-password', 'Password is required'); valid = false; }

      if (password && cpassword && password !== cpassword) {
        setError('err-cpassword', 'Passwords do not match');
        valid = false;
      }

      if (!valid) return;

      try {
        const res = await fetch('/signup', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username, email, password })
        });

        const text = await res.text();

        if (!res.ok) {
          showToast(text, 'error');
          return;
        }

        showToast(text, 'success');
        setTimeout(() => window.location.href = '/', 800);

      } catch (err) {
        console.error(err);
        showToast('Something went wrong. Try again.', 'error');
      }
    }

    function togglePassword(id, el) {
      const input = document.getElementById(id);
      const icon = el.querySelector('i');
      if (input.type === 'password') {
        input.type = 'text';
        icon.classList.replace('fa-eye', 'fa-eye-slash');
      } else {
        input.type = 'password';
        icon.classList.replace('fa-eye-slash', 'fa-eye');
      }
    }

    // Allow Enter key to submit
    document.addEventListener('keydown', e => {
      if (e.key === 'Enter') getDetails();
    });
  </script>

</body>

</html>