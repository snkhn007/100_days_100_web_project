# AI-Assisted Notes Editor - Backend Configuration
# Copy this file to .env and fill in your actual values

# Google Gemini API Key
# Get your free API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Secret API key for authentication (change this in production!)
# This prevents unauthorized access to your API from other domains
API_SECRET=your_secret_api_key_here

# Server port (default: 3000)
PORT=3000

# Environment (development or production)
NODE_ENV=development
