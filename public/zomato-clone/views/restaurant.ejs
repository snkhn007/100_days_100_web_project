<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Zomato Clone</title>
  <link rel="stylesheet" href="/css/index.css">
  <link rel="stylesheet" href="/css/resturant.css">
</head>

<body>

  <%- include('partials/navbar') %>

  <div class="page-wrapper">

    <h1 class="page-title">Best Food in Delhi NCR</h1>

    <div class="card-container">

      <% foods.forEach(item => { %>
<!-- 
      card onclick for every card to navigate on detail page  -->
        
        <div class="card" onclick="goToDetail('<%= item._id %>')">
 
          <!-- IMAGE SECTION -->
          <div class="card-image-wrap">
            <img
              src="<%= item.images && item.images[0] ? item.images[0] : '/img/placeholder.jpg' %>"
              alt="<%= item.name %>"
              class="card-img"
              loading="lazy"
            />

                       <!-- Promoted Badge -->
            <span class="promoted-badge">Promoted</span>

            <!-- Offer Banner -->
            <% if (item.offer) { %>
              <div class="offer-banner">
                <span class="offer-icon">%</span>
                <%= item.offer %>
              </div>
            <% } else { %>
              <div class="offer-banner">
                <span class="offer-icon">%</span>
                Flat 10% OFF
              </div>
            <% } %>
          </div>

          <!-- CARD CONTENT -->
          <div class="card-content">

            <!-- Name + Rating -->
            <div class="top-row">
              <h3 class="card-name"><%= item.name %></h3>
           <span class="rating-badge">
                <%= item.deliveryRating ? item.deliveryRating.toFixed(1) : (item.diningRating ? item.diningRating.toFixed(1) : "4.0") %>★
              </span>
            </div>

              <!-- Cuisines -->
            <p class="cuisine-text">
              <%= item.cuisines && item.cuisines.length ? item.cuisines.join(", ") : "Food" %>
            </p>

        <!-- Location + Price -->
            <div class="bottom-row">
              <span class="location-text"><%= item.location || "Delhi" %></span>
              <span class="location-text"><%= item.priceForTwo || "Delhi" %></span>

            </div>
            <!-- Distance -->
            <div class="distance-row">
              <span class="distance-text"><%= item.distance || "1 km" %></span>
            </div>

          </div>
        </div>

      <% }) %>

    </div>

  </div>

  <%- include('partials/footer') %>




<script>
function goToDetail(id) {
  window.location.href = `/view/${id}`;
}
</script>

</body>
</html>
