<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Zomato Clone</title>
  <link rel="stylesheet" href="/css/home.css">
  <link rel="stylesheet" href="/css/resturant.css">
</head>

<body>

  <%- include('partials/navbar') %>

  <div class="page-wrapper">

    <h1 class="page-title">Best Food in Delhi NCR</h1>

    <div class="card-container">

      <% foods.forEach(item => { %>

        <div class="card">

          <!-- IMAGE SECTION -->
          <div class="card-image-wrap">
            <img
              src="<%= item.images && item.images[0] ? item.images[0] : '/img/placeholder.jpg' %>"
              alt="<%= item.name %>"
              class="card-img"
              loading="lazy"
            />

           

            <!-- Offer Banner -->
            <% if (item.offer) { %>
              <div class="offer-banner">
                <span class="offer-icon">%</span>
                <%= item.offer %>
              </div>
            <% } else { %>
              <div class="offer-banner">
                <span class="offer-icon">%</span>
                Flat 10% OFF
              </div>
            <% } %>
          </div>

          <!-- CARD CONTENT -->
          <div class="card-content">

            <!-- Name + Rating -->
            <div class="top-row">
              <h3 class="card-name"><%= item.name %></h3>
          
            </div>

           
       
            <!-- Distance -->
            <div class="distance-row">
              <span class="distance-text"><%= item.distance || "1 km" %></span>
            </div>

          </div>
        </div>

      <% }) %>

    <% }) %>

  </div>

  <%- include('partials/footer') %>

  <script>
    const html = document.documentElement;
    const saved = localStorage.getItem('zomato-theme');
    if (saved) html.setAttribute('data-theme', saved);

    function toggleDark() {
      const isDark = html.getAttribute('data-theme') === 'dark';
      const next = isDark ? 'light' : 'dark';
      html.setAttribute('data-theme', next);
      localStorage.setItem('zomato-theme', next);
    }
  </script>

</body>
</html>
